# Dedicated deployer private key. Never use the founder, treasury, or AGIALPHA reserve wallet as deployer.
PRIVATE_KEY=

# Ethereum networks
ETHEREUM_SEPOLIA_RPC_URL=
ETHEREUM_MAINNET_RPC_URL=
ETHERSCAN_API_KEY=

# Existing AGIALPHA token.
# Ethereum mainnet must use exactly 0xA61a3B3a130a9c20768EEBF97E21515A6046a1fA.
# For Ethereum Sepolia rehearsal, leave this blank to deploy MockAGIALPHA automatically.
# If a non-mainnet token address is supplied and has no code, deployment fails unless ALLOW_NONMAINNET_MOCK_ON_MISSING_TOKEN=YES.
AGIALPHA_TOKEN_ADDRESS=
ALLOW_NONMAINNET_MOCK_ON_MISSING_TOKEN=

# Existing legacy AGIJobManager for historical proof references.
LEGACY_AGI_JOB_MANAGER_ADDRESS=0xb3aaeb69b630f0299791679c063d68d6687481d1

# Required deployment/admin addresses. No deployer defaults.
FOUNDER_ADDRESS=
TREASURY_ADDRESS=
COMMERCIALIZATION_PERFORMANCE_ADMIN=
PROOF_REWARDS_ADMIN=
LIQUIDITY_ADMIN=
SECURITY_ADMIN=
COMMUNITY_ADMIN=

# Mainnet gate.
MAINNET_TARGET=ethereum
ALLOW_MAINNET_DEPLOYMENT=
# Required only for final manual deployment after generated authorization YES:
# YES_FOUNDER_APPROVED_MAINNET_AUTHORIZATION
MAINNET_DEPLOYMENT_CONFIRMATION=

# Required mainnet signoff hashes. Use 0x-prefixed 32-byte hashes.
LEGAL_SIGNOFF_HASH=
TAX_SIGNOFF_HASH=
SECURITY_REVIEW_HASH=
PUBLIC_CLAIMS_REVIEW_HASH=
TREASURY_REVIEW_HASH=
AGIALPHA_TOKEN_VERIFICATION_HASH=
SEPOLIA_REHEARSAL_EVIDENCE_HASH=
AUTOMATED_SECURITY_TOOLCHAIN_HASH=
INTERNAL_SECURITY_REVIEW_HASH=
FOUNDER_APPROVAL_HASH=

# Optional post-deployment AGIALPHA vault funding gates.
ALLOW_VAULT_FUNDING=
VAULT_FUNDING_APPROVAL_HASH=
FUND_COMMERCIALIZATION_VAULT=0
FUND_PROOF_REWARDS_VAULT=0
FUND_LIQUIDITY_VAULT=0
FUND_SECURITY_VAULT=0
FUND_COMMUNITY_VAULT=0

# v3.0 optional AEP / mandate fee configuration is configured on-chain after deployment.
# Mainnet deployment uses existing AGIALPHA only; no new token is deployed.
