{
  "policyVersion": "1.0.0",
  "product": "GoalOS Mission OS",
  "category": "The Proof OS for Autonomous AI Work",
  "canonicalPromise": "Set the objective. GoalOS runs until proof is done.",
  "doctrine": [
    "AI creates output. GoalOS creates proof.",
    "The deliverable is not a document. The deliverable is a governed decision state.",
    "No proof, no settlement.",
    "No eval, no propagation.",
    "No rollback, no release."
  ],
  "humanGateRequiredFor": [
    "public_claim_promotion",
    "production_release",
    "mainnet_broadcast",
    "token_movement",
    "external_customer_claim",
    "security_certification_claim",
    "legal_financial_medical_advice"
  ],
  "forbiddenClaims": [
    "achieved agi",
    "achieved asi",
    "superintelligence achieved",
    "guaranteed roi",
    "guaranteed return",
    "legal advice",
    "financial advice",
    "medical advice",
    "production-ready",
    "externally audited",
    "cybersecurity certified",
    "mainnet deployed",
    "guaranteed market outcome",
    "guaranteed investment outcome",
    "kardashev achieved",
    "safe autonomous production remediation"
  ],
  "requiredArtifacts": [
    "GoalOSCommit.md",
    "RunCommitment.md",
    "MissionPlan.md",
    "WorkGraph.json",
    "ClaimsMatrix.csv",
    "SourceProvenance.csv",
    "ContradictionRegister.md",
    "EvidenceDocket.md",
    "VerifierReport.md",
    "RiskLedger.csv",
    "DecisionState.json",
    "ExecutiveBrief.md",
    "DecisionDeck.md",
    "ActionGraph.md",
    "ChronicleEntry.md",
    "CapabilityPackage.md",
    "ClaimBoundaryReport.md",
    "QAReport.md",
    "artifact-manifest.json",
    "index.html",
    "run-state.json"
  ],
  "doneGates": [
    "mission_objective_clear",
    "claims_matrix_present",
    "source_provenance_present",
    "evidence_docket_present",
    "contradiction_register_present",
    "verifier_report_present",
    "risk_ledger_present",
    "decision_state_present",
    "action_graph_present",
    "chronicle_entry_present",
    "capability_package_present",
    "claim_boundary_passed",
    "qa_passed",
    "artifact_manifest_present"
  ]
}
