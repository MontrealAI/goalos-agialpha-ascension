{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://montrealai.github.io/goalos-agialpha-ascension/schemas/goalos-mission-os-intake.schema.json",
  "title": "GoalOS Mission OS Intake",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_id",
    "mission_title",
    "objective",
    "decision_to_support",
    "success_criteria",
    "failure_criteria",
    "constraints",
    "allowed_sources",
    "private_data_boundary",
    "risk_class",
    "deadline",
    "output_package",
    "reviewer_required",
    "claim_boundary",
    "done_condition",
    "ethereum_settlement_mode",
    "ethereum_network",
    "agialpha_token_address"
  ],
  "properties": {
    "mission_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,96}$"
    },
    "mission_title": {
      "type": "string",
      "minLength": 8,
      "maxLength": 180
    },
    "objective": {
      "type": "string",
      "minLength": 8,
      "maxLength": 1000
    },
    "decision_to_support": {
      "type": "string",
      "minLength": 8,
      "maxLength": 700
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "failure_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "private_data_boundary": {
      "type": "string",
      "minLength": 3
    },
    "risk_class": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "strategic"
      ]
    },
    "deadline": {
      "type": "string"
    },
    "output_package": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string"
      }
    },
    "reviewer_required": {
      "type": "boolean",
      "default": true
    },
    "claim_boundary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "done_condition": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "ethereum_settlement_mode": {
      "type": "string",
      "enum": [
        "none",
        "simulation",
        "sepolia",
        "mainnet-readiness",
        "mainnet-local-only-after-human-gate"
      ],
      "default": "none"
    },
    "ethereum_network": {
      "type": "string",
      "enum": [
        "none",
        "hardhat",
        "ethereumSepolia",
        "ethereumMainnet"
      ]
    },
    "agialpha_token_address": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{40}$"
    },
    "requires_contract_deployment": {
      "type": "boolean",
      "default": false
    },
    "requires_contract_verification": {
      "type": "boolean",
      "default": false,
      "const": false,
      "description": "Mission OS does not accept verification-required intake until deployment manifest, constructor arguments, and verification evidence capture are supplied. Use existing Hardhat verification workflows and evidence validators."
    },
    "requires_mainnet_broadcast": {
      "type": "boolean",
      "default": false,
      "const": false
    },
    "requires_token_movement": {
      "type": "boolean",
      "default": false,
      "const": false
    },
    "publication_mode": {
      "type": "string",
      "enum": [
        "none",
        "local-only",
        "human-review-pr",
        "github-pages-after-review"
      ],
      "default": "human-review-pr"
    },
    "paper_links_required": {
      "type": "boolean",
      "default": false
    },
    "website_publication_required": {
      "type": "boolean",
      "default": false
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "ethereum_network": {
            "const": "ethereumMainnet"
          }
        },
        "required": [
          "ethereum_network"
        ]
      },
      "then": {
        "properties": {
          "agialpha_token_address": {
            "const": "0xA61a3B3a130a9c20768EEBF97E21515A6046a1fA"
          }
        },
        "required": [
          "agialpha_token_address"
        ]
      }
    }
  ]
}
