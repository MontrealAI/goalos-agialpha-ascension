{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://montrealai.github.io/goalos-agialpha-ascension/schemas/goalos-mission-os-intake.schema.json",
  "title": "GoalOS Mission OS Intake",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_id",
    "mission_title",
    "decision_to_support",
    "success_criteria",
    "failure_criteria",
    "constraints",
    "allowed_sources",
    "private_data_boundary",
    "risk_class",
    "deadline",
    "output_package",
    "reviewer_required",
    "claim_boundary",
    "done_condition"
  ],
  "properties": {
    "mission_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,96}$"},
    "mission_title": {"type": "string", "minLength": 8, "maxLength": 180},
    "decision_to_support": {"type": "string", "minLength": 8, "maxLength": 500},
    "success_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
    "failure_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "allowed_sources": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "private_data_boundary": {"type": "string", "minLength": 3},
    "risk_class": {"type": "string", "enum": ["low", "medium", "high", "strategic"]},
    "deadline": {"type": "string"},
    "output_package": {"type": "array", "minItems": 3, "items": {"type": "string"}},
    "reviewer_required": {"type": "boolean"},
    "claim_boundary": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "done_condition": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "notes": {"type": "string"}
  }
}
