{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://montrealai.github.io/goalos-agialpha-ascension/schemas/agi-jobs-v0-v2-evidence-docket.schema.json",
  "title": "GoalOS AGIALPHA Ascension AGI Jobs v0 (v2) Evidence Docket v3",
  "description": "A deterministic, browser-local review object for the Sovereign Work Civilization. It is evidence, not permission.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "release_id",
    "release_title",
    "version",
    "run_id",
    "work_constitution",
    "market",
    "work_graph",
    "parliament",
    "guardians",
    "incident",
    "evidence",
    "settlement",
    "memory",
    "authority",
    "claim_boundary",
    "run_commitment"
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "zero": {
      "const": 0
    },
    "noneGranted": {
      "const": "NONE_GRANTED"
    }
  },
  "properties": {
    "schema": {
      "const": "goalos.agi_jobs_v0_v2.evidence_docket.v3"
    },
    "release_id": {
      "const": "GOALOS-AGIALPHA-AGI-JOBS-V0-V2-002"
    },
    "release_title": {
      "const": "GoalOS AGIALPHA Ascension AGI Jobs v0 (v2) ✨"
    },
    "version": {
      "const": "3.0.0-sovereign-work-civilization"
    },
    "run_id": {
      "type": "string",
      "pattern": "^AJ-[A-F0-9]{16}$"
    },
    "work_constitution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission",
        "preset",
        "job_class",
        "posture",
        "risk",
        "reward_units",
        "deliverables",
        "forbidden_runtime_actions"
      ],
      "properties": {
        "mission": {
          "type": "string",
          "minLength": 30
        },
        "preset": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "job_class": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "posture": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "risk": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "reward_units": {
          "type": "number",
          "minimum": 500,
          "maximum": 100000
        },
        "deliverables": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "forbidden_runtime_actions": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "market": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "leader",
        "frontier",
        "ranking",
        "council"
      ],
      "properties": {
        "leader": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "frontier": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "ranking": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "admitted",
              "score",
              "fit"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "admitted": {
                "type": "boolean"
              },
              "score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "fit": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        },
        "council": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "prime",
            "evidence",
            "assurance",
            "delivery",
            "shadow",
            "reserves"
          ],
          "properties": {
            "id": {
              "type": "string",
              "pattern": "^COUNCIL-[A-F0-9]{12}$"
            },
            "prime": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "evidence": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "assurance": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "delivery": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "shadow": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "reserves": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "$ref": "#/$defs/nonEmptyString"
              }
            }
          }
        }
      }
    },
    "work_graph": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "proof",
          "dependency",
          "owner",
          "role",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^W[0-9]{2}$"
          },
          "status": {
            "const": "COMPLETE"
          }
        }
      }
    },
    "parliament": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seats",
        "threshold",
        "pass",
        "reject",
        "dissent",
        "abstain",
        "judgments"
      ],
      "properties": {
        "seats": {
          "const": 9
        },
        "threshold": {
          "const": 7
        },
        "pass": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "reject": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "dissent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "abstain": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "judgments": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "items": {
            "type": "object",
            "required": [
              "id",
              "name",
              "focus",
              "verdict",
              "score",
              "rationale",
              "salt",
              "commitment",
              "conflict"
            ],
            "properties": {
              "verdict": {
                "enum": [
                  "PASS",
                  "DISSENT",
                  "REJECT",
                  "ABSTAIN"
                ]
              },
              "score": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "salt": {
                "type": "string",
                "pattern": "^[a-f0-9]{16}$"
              },
              "commitment": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        }
      }
    },
    "guardians": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "veto",
          "status"
        ],
        "properties": {
          "status": {
            "enum": [
              "CLEAR",
              "VETO"
            ]
          }
        }
      }
    },
    "incident": {
      "type": "object",
      "required": [
        "id",
        "label",
        "severity",
        "terminal",
        "effect"
      ],
      "properties": {
        "id": {
          "const": "none"
        },
        "terminal": {
          "const": "HUMAN_SETTLEMENT_REVIEW"
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_count",
        "chain_head",
        "artifacts"
      ],
      "properties": {
        "artifact_count": {
          "const": 24
        },
        "chain_head": {
          "$ref": "#/$defs/sha256"
        },
        "artifacts": {
          "type": "array",
          "minItems": 24,
          "maxItems": 24,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "name",
              "plane",
              "purpose",
              "previous_commitment",
              "commitment",
              "payload"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^A[0-9]{2}$"
              },
              "name": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "plane": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "purpose": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "previous_commitment": {
                "$ref": "#/$defs/sha256"
              },
              "commitment": {
                "$ref": "#/$defs/sha256"
              },
              "payload": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "settlement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "unit",
        "allocation",
        "conditions_precedent",
        "live_token_movement",
        "wallet_connections",
        "settlement_authority"
      ],
      "properties": {
        "mode": {
          "const": "demonstration-constitutional-settlement-model-only"
        },
        "unit": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "allocation": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6
        },
        "conditions_precedent": {
          "type": "array",
          "minItems": 6,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "live_token_movement": {
          "$ref": "#/$defs/zero"
        },
        "wallet_connections": {
          "$ref": "#/$defs/zero"
        },
        "settlement_authority": {
          "$ref": "#/$defs/noneGranted"
        }
      }
    },
    "memory": {
      "type": "object",
      "required": [
        "reputation_delta_candidate",
        "capability_passport_candidate"
      ],
      "properties": {
        "reputation_delta_candidate": {
          "type": "object"
        },
        "capability_passport_candidate": {
          "type": "object",
          "required": [
            "institution",
            "status",
            "scope",
            "skills",
            "expiry",
            "revocable",
            "transferable"
          ],
          "properties": {
            "status": {
              "const": "HUMAN_APPROVAL_PENDING"
            },
            "revocable": {
              "const": true
            },
            "transferable": {
              "const": false
            }
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "terminal_state",
        "external_authority",
        "production_activation",
        "user_fund_authorization",
        "external_actions",
        "network_requests",
        "wallet_connections",
        "live_token_movements",
        "factual_correctness"
      ],
      "properties": {
        "terminal_state": {
          "enum": [
            "HUMAN_SETTLEMENT_REVIEW",
            "HUMAN_REVIEW_REQUIRED",
            "DISPUTE_OPEN",
            "SAFE_HOLD"
          ]
        },
        "external_authority": {
          "$ref": "#/$defs/noneGranted"
        },
        "production_activation": {
          "const": "NOT_ACTIVATED"
        },
        "user_fund_authorization": {
          "const": "NO"
        },
        "external_actions": {
          "$ref": "#/$defs/zero"
        },
        "network_requests": {
          "$ref": "#/$defs/zero"
        },
        "wallet_connections": {
          "$ref": "#/$defs/zero"
        },
        "live_token_movements": {
          "$ref": "#/$defs/zero"
        },
        "factual_correctness": {
          "const": "NOT_CERTIFIED"
        }
      }
    },
    "claim_boundary": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "run_commitment": {
      "$ref": "#/$defs/sha256"
    }
  }
}
