{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://montrealai.github.io/goalos-agialpha-ascension/schemas/sovereign-machine-economy-docket.schema.json",
  "title": "GoalOS AGIALPHA Ascension Sovereign Machine Economy Evidence Docket v1",
  "description": "A deterministic, browser-local constitutional review object binding META-Agentic institution formation, AGI Alpha Node proof execution, AGI Jobs market coordination, and the final human authority boundary. Evidence is not permission.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "release_id",
    "version",
    "mission",
    "meta",
    "node",
    "jobs",
    "handoffs",
    "companions",
    "evidence",
    "authority",
    "run_commitment"
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "zero": {
      "const": 0
    },
    "noneGranted": {
      "const": "NONE_GRANTED"
    }
  },
  "properties": {
    "schema": {
      "const": "goalos.sovereign_machine_economy.docket.v1"
    },
    "release_id": {
      "const": "GOALOS-SOVEREIGN-MACHINE-ECONOMY-001"
    },
    "version": {
      "const": "1.0.0-civilization"
    },
    "mission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text",
        "posture",
        "risk",
        "incident",
        "commitment"
      ],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 30
        },
        "posture": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "risk": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "incident": {
          "enum": [
            "none",
            "institution-divergence",
            "node-identity-drift",
            "evidence-gap",
            "budget-breach"
          ]
        },
        "commitment": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_institution",
        "candidate_count",
        "pareto_review",
        "constitution_seal"
      ],
      "properties": {
        "selected_institution": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "id",
            "name",
            "topology",
            "score"
          ],
          "properties": {
            "id": {
              "pattern": "^I[0-9]{2}$",
              "type": "string"
            },
            "name": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "topology": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          }
        },
        "candidate_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 36
        },
        "pareto_review": {
          "enum": [
            "COMPLETE",
            "WITHHELD"
          ]
        },
        "constitution_seal": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "primary",
        "shadow",
        "work_unit_id",
        "evidence_seal"
      ],
      "properties": {
        "route_id": {
          "type": "string",
          "pattern": "^ROUTE-[A-F0-9]{12}$"
        },
        "primary": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "shadow": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "work_unit_id": {
          "type": "string",
          "pattern": "^AWU-[A-F0-9]{16}$"
        },
        "evidence_seal": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "jobs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coalition_id",
        "coalition",
        "pareto_frontier",
        "parliament",
        "market_seal"
      ],
      "properties": {
        "coalition_id": {
          "type": "string",
          "pattern": "^COUNCIL-[A-F0-9]{12}$"
        },
        "coalition": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "pareto_frontier": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "parliament": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "seats",
            "threshold",
            "pass",
            "dissent",
            "reject",
            "challenge_window"
          ],
          "properties": {
            "seats": {
              "enum": [
                3,
                5,
                7,
                9
              ]
            },
            "threshold": {
              "type": "integer",
              "minimum": 2,
              "maximum": 9
            },
            "pass": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9
            },
            "dissent": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9
            },
            "reject": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9
            },
            "challenge_window": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        },
        "market_seal": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "handoffs": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "from",
          "to",
          "commitment"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^H0[1-3]$"
          },
          "from": {
            "enum": [
              "META",
              "NODE",
              "JOBS"
            ]
          },
          "to": {
            "enum": [
              "NODE",
              "JOBS",
              "HUMAN"
            ]
          },
          "commitment": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    },
    "companions": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "layer",
          "release_id",
          "version"
        ],
        "properties": {
          "layer": {
            "enum": [
              "META",
              "NODE",
              "JOBS"
            ]
          },
          "release_id": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "version": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_count",
        "expected_artifact_count",
        "chain_head",
        "artifacts"
      ],
      "properties": {
        "artifact_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 36
        },
        "expected_artifact_count": {
          "const": 36
        },
        "chain_head": {
          "$ref": "#/$defs/sha256"
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "maxItems": 36,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "layer",
              "name",
              "purpose",
              "previous_commitment",
              "commitment",
              "payload"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[MNJ][0-9]{2}$"
              },
              "layer": {
                "enum": [
                  "META",
                  "NODE",
                  "JOBS"
                ]
              },
              "name": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "purpose": {
                "$ref": "#/$defs/nonEmptyString"
              },
              "previous_commitment": {
                "$ref": "#/$defs/sha256"
              },
              "commitment": {
                "$ref": "#/$defs/sha256"
              },
              "payload": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "id",
                  "layer",
                  "name",
                  "purpose",
                  "mission_commitment",
                  "institution_id",
                  "route_id",
                  "coalition_id",
                  "terminal"
                ],
                "properties": {
                  "id": {
                    "type": "string",
                    "pattern": "^[MNJ][0-9]{2}$"
                  },
                  "layer": {
                    "enum": [
                      "META",
                      "NODE",
                      "JOBS"
                    ]
                  },
                  "name": {
                    "$ref": "#/$defs/nonEmptyString"
                  },
                  "purpose": {
                    "$ref": "#/$defs/nonEmptyString"
                  },
                  "mission_commitment": {
                    "$ref": "#/$defs/sha256"
                  },
                  "institution_id": {
                    "type": "string",
                    "pattern": "^I[0-9]{2}$"
                  },
                  "route_id": {
                    "type": "string",
                    "pattern": "^ROUTE-[A-F0-9]{12}$"
                  },
                  "coalition_id": {
                    "type": "string",
                    "pattern": "^COUNCIL-[A-F0-9]{12}$"
                  },
                  "terminal": {
                    "enum": [
                      "HUMAN_SETTLEMENT_REVIEW",
                      "HUMAN_REVIEW_REQUIRED",
                      "DISPUTE_OPEN",
                      "SAFE_HOLD"
                    ]
                  }
                }
              }
            }
          }
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "terminal_state",
        "external_authority",
        "factual_correctness",
        "production_activation",
        "user_fund_authorization",
        "external_actions",
        "network_requests",
        "wallet_connections",
        "live_token_movements",
        "memory_promotion"
      ],
      "properties": {
        "terminal_state": {
          "enum": [
            "HUMAN_SETTLEMENT_REVIEW",
            "HUMAN_REVIEW_REQUIRED",
            "DISPUTE_OPEN",
            "SAFE_HOLD"
          ]
        },
        "external_authority": {
          "$ref": "#/$defs/noneGranted"
        },
        "factual_correctness": {
          "const": "NOT_CERTIFIED"
        },
        "production_activation": {
          "const": "NOT_ACTIVATED"
        },
        "user_fund_authorization": {
          "const": "NO"
        },
        "external_actions": {
          "$ref": "#/$defs/zero"
        },
        "network_requests": {
          "$ref": "#/$defs/zero"
        },
        "wallet_connections": {
          "$ref": "#/$defs/zero"
        },
        "live_token_movements": {
          "$ref": "#/$defs/zero"
        },
        "memory_promotion": {
          "const": "NOT_AUTHORIZED"
        }
      }
    },
    "run_commitment": {
      "$ref": "#/$defs/sha256"
    }
  }
}
