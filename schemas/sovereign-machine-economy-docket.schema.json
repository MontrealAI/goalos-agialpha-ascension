{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://montrealai.github.io/goalos-agialpha-ascension/schemas/sovereign-machine-economy-docket.schema.json",
  "title": "GoalOS Sovereign Machine Economy Ω Evidence Docket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "release_id",
    "run_id",
    "mission",
    "institution",
    "node",
    "market",
    "handoffs",
    "evidence",
    "counterfactuals",
    "review",
    "memory",
    "incident",
    "authority",
    "claim_boundary",
    "economy_root",
    "run_commitment"
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "terminal": {
      "enum": [
        "HUMAN_SETTLEMENT_REVIEW",
        "HUMAN_REVIEW_REQUIRED",
        "DISPUTE_OPEN",
        "SAFE_HOLD"
      ]
    }
  },
  "properties": {
    "schema": {
      "const": "goalos.sovereign_machine_economy.docket.v2"
    },
    "release_id": {
      "const": "GOALOS-AGIALPHA-SOVEREIGN-MACHINE-ECONOMY-002"
    },
    "run_id": {
      "type": "string",
      "pattern": "^SME-[A-F0-9]{16}$"
    },
    "mission": {
      "type": "object",
      "required": [
        "mission",
        "preset",
        "domain",
        "posture",
        "risk",
        "incident"
      ]
    },
    "institution": {
      "type": "object",
      "required": [
        "id",
        "name",
        "roles",
        "metrics",
        "candidate_count",
        "frontier_count",
        "lineage_root",
        "charter_commitment",
        "authority"
      ],
      "properties": {
        "lineage_root": {
          "$ref": "#/$defs/sha256"
        },
        "charter_commitment": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "node": {
      "type": "object",
      "required": [
        "id",
        "route_id",
        "primary",
        "shadow",
        "identity_commitment",
        "resource_constitution",
        "resource_commitment",
        "receipt_id",
        "external_actions",
        "wallet_connections",
        "network_requests"
      ],
      "properties": {
        "identity_commitment": {
          "$ref": "#/$defs/sha256"
        },
        "resource_commitment": {
          "$ref": "#/$defs/sha256"
        },
        "external_actions": {
          "const": 0
        },
        "wallet_connections": {
          "const": 0
        },
        "network_requests": {
          "const": 0
        }
      }
    },
    "market": {
      "type": "object",
      "required": [
        "id",
        "frontier",
        "coalition_id",
        "coalition",
        "parliament",
        "challenge_hours",
        "charter_commitment",
        "settlement"
      ],
      "properties": {
        "charter_commitment": {
          "$ref": "#/$defs/sha256"
        },
        "settlement": {
          "type": "object",
          "required": [
            "status",
            "live",
            "wallet_connection",
            "token_movement",
            "external_actions"
          ],
          "properties": {
            "status": {
              "const": "HUMAN_SETTLEMENT_REVIEW"
            },
            "live": {
              "const": false
            },
            "wallet_connection": {
              "const": false
            },
            "token_movement": {
              "const": false
            },
            "external_actions": {
              "const": 0
            }
          }
        }
      }
    },
    "handoffs": {
      "type": "array",
      "minItems": 15,
      "maxItems": 15,
      "items": {
        "type": "object",
        "required": [
          "id",
          "from",
          "to",
          "name",
          "purpose",
          "previous_commitment",
          "commitment"
        ],
        "properties": {
          "previous_commitment": {
            "$ref": "#/$defs/sha256"
          },
          "commitment": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "required": [
        "artifact_count",
        "chain_head",
        "artifacts"
      ],
      "properties": {
        "artifact_count": {
          "const": 48
        },
        "chain_head": {
          "$ref": "#/$defs/sha256"
        },
        "artifacts": {
          "type": "array",
          "minItems": 48,
          "maxItems": 48,
          "items": {
            "type": "object",
            "required": [
              "id",
              "plane",
              "name",
              "previous_commitment",
              "artifact_hash",
              "commitment",
              "payload"
            ],
            "properties": {
              "plane": {
                "enum": [
                  "MIND",
                  "NODE",
                  "MARKET"
                ]
              },
              "previous_commitment": {
                "$ref": "#/$defs/sha256"
              },
              "artifact_hash": {
                "$ref": "#/$defs/sha256"
              },
              "commitment": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        }
      }
    },
    "counterfactuals": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "promise",
          "posture",
          "institution",
          "route",
          "coalition",
          "terminal_state",
          "authority",
          "external_actions",
          "scores",
          "commitment"
        ],
        "properties": {
          "terminal_state": {
            "const": "HUMAN_SETTLEMENT_REVIEW"
          },
          "authority": {
            "const": "NONE_GRANTED"
          },
          "external_actions": {
            "const": 0
          },
          "commitment": {
            "$ref": "#/$defs/sha256"
          }
        }
      }
    },
    "review": {
      "type": "object",
      "required": [
        "status",
        "selected_action",
        "record",
        "available_actions",
        "authority_granted",
        "settlement_authorized",
        "memory_promoted"
      ],
      "properties": {
        "status": {
          "enum": [
            "PENDING_HUMAN_REVIEW",
            "APPROVED_FOR_DELIBERATION",
            "REVISION_REQUESTED",
            "DISPUTE_OPEN",
            "REJECTED_BY_REVIEW"
          ]
        },
        "selected_action": {
          "type": [
            "string",
            "null"
          ]
        },
        "record": {
          "type": [
            "string",
            "null"
          ]
        },
        "available_actions": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4
        },
        "authority_granted": {
          "const": false
        },
        "settlement_authorized": {
          "const": false
        },
        "memory_promoted": {
          "const": false
        }
      }
    },
    "memory": {
      "type": "object",
      "required": [
        "id",
        "status",
        "scope",
        "expiry",
        "revocable",
        "evidence_root",
        "automatic_promotion",
        "failure_memory_preserved"
      ],
      "properties": {
        "status": {
          "const": "HUMAN_PROMOTION_REQUIRED"
        },
        "revocable": {
          "const": true
        },
        "evidence_root": {
          "$ref": "#/$defs/sha256"
        },
        "automatic_promotion": {
          "const": false
        },
        "failure_memory_preserved": {
          "const": true
        }
      }
    },
    "incident": {
      "type": "object",
      "required": [
        "id",
        "label",
        "effect",
        "stop_gate"
      ],
      "properties": {
        "stop_gate": {
          "type": "integer",
          "minimum": 0,
          "maximum": 21
        }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "terminal_state",
        "external_authority",
        "factual_correctness",
        "production_activation",
        "user_fund_authorization",
        "automatic_memory_promotion",
        "external_actions",
        "network_requests",
        "wallet_connections",
        "live_token_movements"
      ],
      "properties": {
        "terminal_state": {
          "$ref": "#/$defs/terminal"
        },
        "external_authority": {
          "const": "NONE_GRANTED"
        },
        "factual_correctness": {
          "const": "NOT_CERTIFIED"
        },
        "production_activation": {
          "const": "NOT_ACTIVATED"
        },
        "user_fund_authorization": {
          "const": "NO"
        },
        "automatic_memory_promotion": {
          "const": "NOT_AUTHORIZED"
        },
        "external_actions": {
          "const": 0
        },
        "network_requests": {
          "const": 0
        },
        "wallet_connections": {
          "const": 0
        },
        "live_token_movements": {
          "const": 0
        }
      }
    },
    "claim_boundary": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "items": {
        "type": "string"
      }
    },
    "economy_root": {
      "$ref": "#/$defs/sha256"
    },
    "run_commitment": {
      "$ref": "#/$defs/sha256"
    }
  }
}
