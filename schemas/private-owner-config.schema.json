{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goalos.local/schemas/private-owner-config.schema.json",
  "title": "GoalOS private production owner configuration",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "chainId", "safeAddress", "expectedThreshold", "expectedOwners", "safeVersion"],
      "properties": {
        "kind": { "const": "SAFE" },
        "chainId": { "const": 1 },
        "safeAddress": { "$ref": "#/$defs/address" },
        "expectedThreshold": { "type": "integer", "minimum": 1 },
        "expectedOwners": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/address" } },
        "safeVersion": { "type": "string", "minLength": 1 },
        "publishSafeThresholdAndOwnerCount": { "type": "boolean", "default": false },
        "notes": { "type": "string" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "chainId", "ownerAddress", "hardwareWalletAcknowledgement"],
      "properties": {
        "kind": { "const": "EOA" },
        "chainId": { "const": 1 },
        "ownerAddress": { "$ref": "#/$defs/address" },
        "hardwareWalletAcknowledgement": { "const": true },
        "notes": { "type": "string" }
      }
    }
  ],
  "$defs": { "address": { "type": "string", "pattern": "^0x[a-fA-F0-9]{40}$" } }
}
