{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goalos.local/schemas/deployment-mainnet-runtime.schema.json",
  "title": "GoalOS Ethereum Mainnet local runtime deployment input",
  "type": "object",
  "required": [
    "schemaVersion",
    "network",
    "chainId",
    "agialphaToken",
    "temporaryDeployerAddress",
    "finalLedgerOwnerAddress",
    "finalOwnerKind",
    "treasuryAddress",
    "governanceOwnerAddress",
    "operationsAddress",
    "founderAddress",
    "permanentAdminAddress",
    "vaultAdminAddress",
    "controllerAddress",
    "canaryLimits",
    "feeCeilings",
    "confirmationPolicy"
  ],
  "properties": {
    "schemaVersion": {
      "const": "2.0"
    },
    "network": {
      "const": "mainnet"
    },
    "hardhatNetwork": {
      "const": "ethereumMainnet"
    },
    "chainId": {
      "const": 1
    },
    "expectedChainId": {
      "const": 1
    },
    "agialphaToken": {
      "const": "0xA61a3B3a130a9c20768EEBF97E21515A6046a1fA"
    },
    "temporaryDeployerAddress": {
      "$ref": "#/$defs/address"
    },
    "finalLedgerOwnerAddress": {
      "$ref": "#/$defs/address"
    },
    "finalOwnerKind": {
      "enum": [
        "LEDGER_EOA"
      ]
    },
    "treasuryAddress": {
      "$ref": "#/$defs/address"
    },
    "governanceOwnerAddress": {
      "$ref": "#/$defs/address"
    },
    "operationsAddress": {
      "$ref": "#/$defs/address"
    },
    "founderAddress": {
      "$ref": "#/$defs/address"
    },
    "permanentAdminAddress": {
      "$ref": "#/$defs/address"
    },
    "vaultAdminAddress": {
      "$ref": "#/$defs/address"
    },
    "controllerAddress": {
      "$ref": "#/$defs/address"
    },
    "canaryLimits": {
      "type": "object"
    },
    "feeCeilings": {
      "type": "object"
    },
    "confirmationPolicy": {
      "type": "object"
    }
  },
  "$defs": {
    "address": {
      "type": "string",
      "pattern": "^0x(?!0{40})[0-9a-fA-F]{40}$"
    }
  },
  "additionalProperties": true
}
