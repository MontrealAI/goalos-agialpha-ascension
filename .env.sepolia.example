# GoalOS AGIALPHA Sepolia deployment environment.
# Copy to .env.sepolia.local, fill locally or configure protected GitHub Environment secrets, and never commit filled .env files.
# Sepolia chainId must be 11155111.

# Required: private Sepolia RPC endpoint. Prefer PRIVATE_SEPOLIA_RPC_URL.
PRIVATE_SEPOLIA_RPC_URL=
SEPOLIA_RPC_URL=
ETHEREUM_SEPOLIA_RPC_URL=

# Required for live deploy: Sepolia deployer private key, 0x-prefixed 64 hex chars.
PRIVATE_SEPOLIA_DEPLOYER_PRIVATE_KEY=
SEPOLIA_DEPLOYER_PRIVATE_KEY=

# Optional unless running verification.
ETHERSCAN_API_KEY=

# Optional: existing Sepolia AGIALPHA-compatible ERC20 token.
AGIALPHA_TOKEN_ADDRESS=

# Optional: Sepolia mock token only if the selected deployment path intentionally allows a rehearsal mock.
MOCK_AGIALPHA_ADDRESS=

# Optional on Sepolia only. Leave blank unless an approved rehearsal deploys a mock token.
DEPLOY_NEW_AGIALPHA_TOKEN=
