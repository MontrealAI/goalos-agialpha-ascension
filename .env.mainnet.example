# GoalOS AGIALPHA Ethereum Mainnet local-only deployment environment.
# Copy values into .private/mainnet-operator.env. Never commit this file when filled.
# Mainnet chainId must be 1. Final broadcast is local-only and never CI/GitHub Actions.

# Required locally only: private Ethereum Mainnet RPC endpoint. Prefer PRIVATE_MAINNET_RPC_URL.
PRIVATE_MAINNET_RPC_URL=
MAINNET_RPC_URL=
ETHEREUM_MAINNET_RPC_URL=

# Required locally only: Ethereum Mainnet deployer private key, 0x-prefixed 64 hex chars.
PRIVATE_MAINNET_DEPLOYER_PRIVATE_KEY=
MAINNET_DEPLOYER_PRIVATE_KEY=

# Optional unless running verification.
ETHERSCAN_API_KEY=

# Required safety target. Must remain ethereum.
MAINNET_TARGET=ethereum

# Required canonical AGIALPHA token. MockAGIALPHA and new token deployment are forbidden on Mainnet.
AGIALPHA_TOKEN_ADDRESS=0xA61a3B3a130a9c20768EEBF97E21515A6046a1fA

# Required only at final local broadcast time.
MAINNET_DEPLOYMENT_CONFIRMATION=

# Required only inside the final local gated deploy shell; never set in GitHub Actions.
ALLOW_MAINNET_DEPLOYMENT=
