{
  "name": "goalos-agialpha-ascension",
  "version": "4.3.0",
  "description": "GoalOS-native reimplementation of α-AGI Ascension using existing AGIALPHA for proof-settled AI workflow work.",
  "license": "MIT",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:agialpha": "hardhat test test/agialphaAscensionFlow.test.ts",
    "static-check": "python scripts/static_check.py",
    "direct-solc-compile": "node scripts/direct-solc-compile.js",
    "generate-artifacts-from-solc": "node scripts/generate-artifacts-from-solc.js",
    "test:no-compile": "hardhat test --no-compile",
    "deploy:ethereum-sepolia": "hardhat run scripts/deploy-ethereum-sepolia.ts --network sepolia",
    "preflight:ethereum-mainnet": "ts-node scripts/preflight-ethereum-mainnet-gates.ts",
    "deploy:ethereum-mainnet:gated": "hardhat run scripts/deploy-ethereum-mainnet-gated.ts --network mainnet",
    "verify:agialpha-token": "hardhat run scripts/verify-agialpha-token.ts --network mainnet",
    "verify:deployment": "hardhat run scripts/verify-deployment.ts --network mainnet",
    "generate:vault-funding-instructions": "ts-node scripts/generate-vault-funding-instructions.ts ethereum-mainnet",
    "fund:vaults:gated": "hardhat run scripts/fund-vaults-agialpha-gated.ts --network mainnet",
    "test:aep": "hardhat test test/aepAscensionFlow.test.ts",
    "test:all": "hardhat test test/agialphaAscensionFlow.test.ts test/aepAscensionFlow.test.ts test/v4InstitutionalControls.test.ts test/v4_3EthereumGateConsistency.test.ts",
    "test:v4": "hardhat test test/v4InstitutionalControls.test.ts",
    "evidence:docket:template": "python scripts/generate-evidence-docket-template.py",
    "mainnet:authorization-check": "python scripts/mainnet-authorization-check.py",
    "ci:advisory": "python scripts/repository_safety_check.py && python scripts/repository_status_check.py && python scripts/repository_production_readiness_check.py && python scripts/no_paid_products_check.py && python scripts/static_check.py && python scripts/verify-readiness-v4-3.py && python scripts/generate-evidence-docket-template.py && python scripts/mainnet-authorization-check.py",
    "readiness:v4.3": "python scripts/verify-readiness-v4-3.py",
    "test:v4.3": "hardhat test test/v4_3EthereumGateConsistency.test.ts",
    "repo:safety": "python scripts/repository_safety_check.py",
    "repo:status": "python scripts/repository_status_check.py",
    "repo:production-readiness": "python scripts/repository_production_readiness_check.py",
    "repo:all": "python scripts/repository_safety_check.py && python scripts/repository_status_check.py && python scripts/repository_production_readiness_check.py && python scripts/no_paid_products_check.py",
    "repo:no-paid-products": "python scripts/no_paid_products_check.py",
    "audit:slither": "bash scripts/audit/run-slither.sh",
    "audit:echidna": "bash scripts/audit/run-echidna.sh",
    "audit:mythril": "bash scripts/audit/run-mythril.sh",
    "audit:medusa": "bash scripts/audit/run-medusa.sh",
    "audit:foundry": "bash scripts/audit/run-foundry.sh",
    "audit:all": "bash scripts/audit/run-all-audits.sh",
    "audit:summarize": "python scripts/audit/summarize-audit-results.py",
    "audit:fail-on-critical": "python scripts/audit/fail-on-critical-findings.py",
    "sepolia:rehearsal": "hardhat run scripts/rehearse-ethereum-sepolia.ts --network sepolia",
    "sepolia:evidence": "python scripts/generate-sepolia-evidence-docket.py",
    "mainnet:technical-preflight": "npm run preflight:ethereum-mainnet && npm run verify:agialpha-token && npm run mainnet:readiness-check && npm run mainnet:authorization-check",
    "audit:semgrep": "bash scripts/audit/run-semgrep.sh",
    "audit:npm": "bash scripts/audit/run-npm-audit.sh",
    "assert:public-status": "python scripts/assert_public_status.py",
    "audit:halmos": "bash scripts/audit/run-halmos.sh",
    "audit:solhint": "bash scripts/audit/run-solhint.sh",
    "audit:smt": "bash scripts/audit/run-solc-smtchecker.sh",
    "audit:osv": "bash scripts/audit/run-osv-scanner.sh",
    "audit:actions": "bash scripts/audit/run-actionlint.sh",
    "audit:shell": "bash scripts/audit/run-shellcheck.sh",
    "audit:secrets": "bash scripts/audit/run-gitleaks.sh",
    "audit:clearance-report": "python scripts/audit/generate-toolchain-clearance-report.py",
    "mainnet:readiness-check": "python scripts/mainnet-readiness-check.py",
    "mainnet:deployment-authorization-check": "python scripts/mainnet-deployment-authorization-check.py",
    "ethereum-mainnet:authorization-check": "python scripts/ethereum-mainnet-authorization-check.py",
    "mainnet:fork-simulate": "HARDHAT_FORK_MAINNET=1 hardhat run scripts/mainnet-fork-simulate.ts --network hardhat"
  },
  "dependencies": {
    "@openzeppelin/contracts": "4.9.6",
    "solc": "0.8.35"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "5.0.0",
    "hardhat": "2.28.6",
    "typescript": "5.9.3",
    "ts-node": "10.9.2"
  },
  "private": true
}
