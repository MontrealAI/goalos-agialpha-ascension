# Copy to a protected local environment file outside git history, for example:
#   cp .private.example/mainnet-readiness.env.example .private/mainnet-readiness.env
# Fill values locally or as GitHub Environment secrets in `mainnet-readiness`.
# Never commit populated .private files.

MAINNET_FORK_RPC_URL=https://mainnet.example.invalid/archive
GOALOS_PRODUCTION_OWNER_KIND=SAFE
GOALOS_PRODUCTION_OWNER_ADDRESS=0x0000000000000000000000000000000000000000
# Base64-encoded JSON matching schemas/private-owner-config.schema.json.
GOALOS_PRODUCTION_OWNER_CONFIG_
# Optional public address with sufficient AGIALPHA balance at the pinned fork block.
FORK_AGIALPHA_FUNDER=0x0000000000000000000000000000000000000000
